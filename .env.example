# Copy to .env at repo root. Loaded by drizzle-kit, db:migrate:down, and pnpm dev:server.
# Host port 5433 matches compose.yml (avoids conflict with Postgres on 5432).
DATABASE_URL=postgres://fes:fes@localhost:5433/fes_dev

# Global tick scheduler interval in ms (default 60000).
# GLOBAL_TICK_INTERVAL_MS=60000

# --- Firebase ---
# Server: Admin SDK via Application Default Credentials (project comes from the JSON key).
GOOGLE_APPLICATION_CREDENTIALS=/path/to/adminsdk.json

# Mobile (#12) + local token script: same values as Firebase Web app config (public client keys).
EXPO_PUBLIC_FIREBASE_API_KEY=
EXPO_PUBLIC_FIREBASE_AUTH_DOMAIN=
EXPO_PUBLIC_FIREBASE_PROJECT_ID=
EXPO_PUBLIC_FIREBASE_APP_ID=

# Local-only: skip Firebase and use Bearer dev:<uid>
# FIREBASE_AUTH_DISABLED=true
