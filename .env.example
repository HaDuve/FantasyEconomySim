# Copy to .env at repo root. Loaded by drizzle-kit, db:migrate:down, and pnpm dev:server.
# Host port 5433 matches compose.yml (avoids conflict with Postgres on 5432).
DATABASE_URL=postgres://fes:fes@localhost:5433/fes_dev

# Global tick scheduler interval in ms (default 60000).
# GLOBAL_TICK_INTERVAL_MS=60000

# Guest connect without Firebase: use Bearer dev:<uid> (see README).
# FIREBASE_AUTH_DISABLED=true

# Firebase Admin for production /auth/connect (Application Default Credentials).
# GOOGLE_APPLICATION_CREDENTIALS=/path/to/service-account.json
